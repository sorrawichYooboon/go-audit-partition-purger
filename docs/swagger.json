{
    "swagger": "2.0",
    "info": {
        "description": "API for testing Audit Log insertions into partitioned DB.",
        "title": "Go Audit Partition Purger API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/v1/audit-logs": {
            "post": {
                "description": "Stores audit log into partitioned table via pg_partman",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "audit"
                ],
                "summary": "Create a new audit log",
                "parameters": [
                    {
                        "description": "Audit Log Data",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.CreateAuditLogRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.CreateAuditLogRequest": {
            "type": "object",
            "required": [
                "action",
                "details",
                "user_id"
            ],
            "properties": {
                "action": {
                    "type": "string",
                    "example": "LOGIN_SUCCESS"
                },
                "details": {
                    "type": "string",
                    "example": "{\"ip\":\"192.168.1.1\"}"
                },
                "user_id": {
                    "type": "string",
                    "example": "USR-001"
                }
            }
        }
    }
}